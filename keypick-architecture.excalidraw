    {
      "type": "text",
      "id": "recovery_desc",
      "x": 1185,
      "y": 590,
      "width": 400,
      "height": 80,
      "text": "keypick setup recovery\n\nFactor 1: recovery_key.age (encrypted file) -> Cloud storage\nFactor 2: Passphrase (written on paper) -> Physical safe\n\nCan decrypt vault if ALL machines are lost",
      "originalText": "keypick setup recovery\n\nFactor 1: recovery_key.age (encrypted file) -> Cloud storage\nFactor 2: Passphrase (written on paper) -> Physical safe\n\nCan decrypt vault if ALL machines are lost",
