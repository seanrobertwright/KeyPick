    {
      "type": "text",
      "id": "gh_actions_desc",
      "x": 640,
      "y": 524,
      "width": 380,
      "height": 85,
      "text": "vault-sync.yml\nTrigger: push to .sops.yaml or vault.yaml\n1. Import SOPS_AGE_KEY from GitHub Secrets\n2. sops updatekeys -y vault.yaml\n3. Auto-commit re-encrypted vault\n4. Push (all machines can now decrypt)",
      "originalText": "vault-sync.yml\nTrigger: push to .sops.yaml or vault.yaml\n1. Import SOPS_AGE_KEY from GitHub Secrets\n2. sops updatekeys -y vault.yaml\n3. Auto-commit re-encrypted vault\n4. Push (all machines can now decrypt)",
