# .sops.yaml
#
# This file lives in the ROOT of your SECRETS git repo (not inside key-pick/ itself).
# It defines which age public keys are authorized to decrypt vault.yaml.
#
# HOW TO GET YOUR PUBLIC KEY:
#   Windows: age-keygen -o %AppData%\sops\age\keys.txt
#   macOS:   age-keygen -o ~/.config/sops/age/keys.txt
#   Linux:   age-keygen -o ~/.config/sops/age/keys.txt
#
# The public key is printed during keygen and starts with "age1..."
#
# AFTER EDITING this file, run:
#   sops updatekeys -y vault.yaml
# OR just push — the GitHub Action will do it for you automatically.

creation_rules:
  - path_regex: vault\.yaml$
    age: >-
      age1REPLACE_WITH_DESKTOP1_PUBLIC_KEY,
      age1REPLACE_WITH_DESKTOP2_PUBLIC_KEY,
      age1REPLACE_WITH_LAPTOP_PUBLIC_KEY,
      age1REPLACE_WITH_GITHUB_ACTIONS_PUBLIC_KEY,
      age1p709v4haaz7xv6ptesrj0gsn3rpuhs6rrg8kslf7d8enynwmualszm45pk,
      age1h8n0564e4jaxqhslweplujpga8lw7xnt5w0zsf6986f7zacpygvqvrcye5,
      age1tzxrsasrwd3hzyfdzhu8q6d0l6r6llm5s3eeht699utfuksguypqqv0m82,
      age1emmqq3jkar4z2r9q8qr0kdw04za2lzm55wfntglz43hyj959hcsq9en592,
      age1vy6qu904z7dm3k58uspxxyhfx5mvwekl3kjnfetm9vye6d0ccdgqnzea83,
      age1fq47erajn8tyg8zxea2us8t6dlh6jufdzw7ccdrmjuq2d6zurfpqmcu7c0
